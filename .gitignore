# =========================
# GERAIS E SISTEMA OPERACIONAL
# =========================
.DS_Store
Thumbs.db
*.log
.env
.env.*
!.env.example

# =========================
# NODE.JS / REACT / TEMPLATES
# =========================
node_modules/
dist/
dist-ssr/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# PYTHON / FLASK (Gerador)
# =========================
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
.pytest_cache/

# =========================
# DOCKER E BANCO DE DADOS
# =========================
.docker/
docker-compose.override.yml
# Ignora possíveis pastas de volumes locais do PostgreSQL
pgdata/
postgres-data/

# =========================
# DIRETÓRIO DE SAÍDA (LPS)
# =========================
# Ignora todas as aplicações e pastas geradas pelo sistema
generator-service/output/*
# Mas mantém a pasta 'output' no repositório através do .gitkeep
!generator-service/output/.gitkeep

# =========================
# EDITORES DE CÓDIGO / IDEs
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# CACHES LOCAIS (Linter, etc)
# =========================
.eslintcache

# =========================
# CONTEXTO LOCAL (GitHub Copilot)
# =========================
.github/