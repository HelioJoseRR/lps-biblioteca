  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  color: #94a3b8;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-corner-action:hover {
  transform: scale(1.1);
  background: white;
  color: var(--primary);
}

.btn-corner-action.active {
  color: #ef4444;
}

.collection-dropdown-wrapper .btn-corner-action.active {
