  color: var(--text-muted);
}

.text-center { text-align: center; }
.text-muted { color: var(--text-muted); }

@media (max-width: 768px) {
  .hero h1 { font-size: 2.5rem; }
  .controls-content { flex-direction: column; gap: 1rem; }
  .sticky-controls { top: 60px; }
  .nav-links { display: none; }
  .form-row { grid-template-columns: 1fr; }
  .col-details-header { flex-direction: column; gap: 1.5rem; }
}
/* ===== NOVO MODAL SELETOR DE COLEÇÃO (HORIZONTAL SCROLL) ===== */
.col-selector-modal {
  max-width: 600px;
  width: 90%;
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: 1rem;
}

.col-selector-body {
  padding: 1.5rem;
}

.collection-carousel {
  display: flex;
  overflow-x: auto;
  gap: 1rem;
  padding-bottom: 1rem;
  /* Esconder scrollbar na aparência mas manter funcionalidade */
