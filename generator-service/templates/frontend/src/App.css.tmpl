  color: var(--secondary);
  text-transform: uppercase;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
}
.admin-table tr:last-child td {
  border-bottom: none;
}
.role-badge {
  padding: 0.25rem 0.75rem;
  border-radius: 2rem;
  font-size: 0.75rem;
  font-weight: 800;
  text-transform: uppercase;
}
.role-badge.admin {
  background: #fef3c7;
  color: #d97706;
}
.role-badge.user {
  background: #e0e7ff;
  color: #4338ca;
}

.btn-sm {
  padding: 0.5rem 1rem;
  font-size: 0.8rem;
}
.btn-outline {
  background: transparent;
  border: 1px solid var(--text-muted);
  color: var(--secondary);
}
.btn-outline:hover {
  background: #f1f5f9;
}

.footer { padding: 4rem; text-align: center; background: #0f172a; color: white; margin-top: 6rem; }

/* Corner Actions (Favorite + Collection) */
.card-actions-corner {
  position: absolute;
  top: 1rem;
  right: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  z-index: 10;
}

.btn-corner-action {
  width: 2.5rem;
  height: 2.5rem;
  background: rgba(255, 255, 255, 0.9);
