                <div className="details-meta">
                  <span className="meta-item">{Icons.calendar} Publicado em {selectedBook.ano || 'N/A'}</span>
                  <span className="meta-item">{Icons.book} {selectedBook.tipo_edicao || 'Edição Comum'}</span>
                </div>
                
                <div className="synopsis">
                  <h3>Sinopse</h3>
                  <p>{selectedBook.sinopse || `Um clássico indispensável que cativa leitores de todas as idades. A narrativa profunda e envolvente de ${selectedBook.autor} transporta o leitor para um universo rico em detalhes, explorando temas universais através de personagens inesquecíveis. Esta obra, categorizada como ${selectedBook.categoria || 'Geral'}, continua a ser uma referência essencial na literatura.`}</p>
                </div>

                <div className="details-actions-bar" style={{ display: 'flex', gap: '1rem', marginTop: '2rem', flexWrap: 'wrap' }}>
                  {enabledFeatures.includes('emprestimo-service') && (
                    <>
                      {myLoan && myLoan.book_id === selectedBook.id ? (
                        <button className="btn-action btn-return" onClick={() => handleReturn(selectedBook.id)} style={{ background: '#dc2626', color: 'white', borderColor: '#b91c1c' }}>
                          {Icons.bookOpen} Devolver Livro
                        </button>
                      ) : borrowedBooks.includes(selectedBook.id) ? (
                        <button className="btn-action btn-unavailable" disabled>
                          {Icons.lock} Indisponível
                        </button>
                      ) : (
                        <button className="btn-action btn-borrow" onClick={() => handleBorrow(selectedBook.id)}>
                          {Icons.bookOpen} Solicitar Empréstimo
                        </button>
                      )}
                    </>
                  )}
                  {isLoggedIn && enabledFeatures.includes('auth-service') && (
                    <button 
                      className={`btn-action btn-outline ${favorites.includes(selectedBook.id) ? 'active' : ''}`}
                      onClick={(e) => { e.stopPropagation(); toggleFavorite(selectedBook.id); }}
