            <span>LibLPS</span>
          </div>
          <p>&copy; 2026 LibLPS — Biblioteca Inteligente</p>
          <div className="footer-links">
            <a href="#">Sobre</a>
            <a href="#">Contato</a>
          </div>
        </div>
      </footer>
      {/* Modal Adicionar Livro na Coleção */}
      {showAddBookToColModal && selectedCollection && (
        <div className="modal-overlay fade-in" onClick={() => setShowAddBookToColModal(false)}>
          <div className="modal-content col-modal animate-pop" onClick={e => e.stopPropagation()}>
            <div className="col-modal-header">
              <div className="col-modal-icon">{Icons.search}</div>
              <h2>Adicionar à Coleção</h2>
              <p>Busque livros do catálogo para adicionar a "{selectedCollection.name}"</p>
              <button className="btn-close" onClick={() => setShowAddBookToColModal(false)} aria-label="Fechar">{Icons.x}</button>
            </div>
            <div className="col-modal-body">
              <div className="search-pill" style={{marginBottom: '1.5rem', width: '100%', maxWidth: '100%'}}>
                <div className="search-icon">{Icons.search}</div>
                <input
                  type="text"
                  placeholder="Pesquisar no catálogo..."
                  value={addBookColSearch}
                  onChange={(e) => setAddBookColSearch(e.target.value)}
                  autoFocus
                />
              </div>
              <div className="add-book-list">
                {livros
                  .filter(l => !selectedCollection.books.includes(l.id))
                  .filter(l => addBookColSearch.length < 2 || l.titulo.toLowerCase().includes(addBookColSearch.toLowerCase()) || l.autor.toLowerCase().includes(addBookColSearch.toLowerCase()))
                  .slice(0, 5)
                  .map(livro => (
                    <div key={livro.id} className="add-book-item">
                      <div className="add-book-thumb" style={{ background: livro.capa_url ? `url("http://localhost:8080/catalogo-service${livro.capa_url}") center/cover` : getCoverGradient(livro.titulo) }}>
                        {!livro.capa_url && <span className="thumb-initial">{livro.titulo.charAt(0)}</span>}
                      </div>
                      <div className="add-book-item-info">
                        <strong>{livro.titulo}</strong>
                        <span>{livro.autor}</span>
                      </div>
                      <button className="btn-action btn-sm" onClick={() => addBookToCollection(selectedCollection.id, livro.id)}>
                        Adicionar
                      </button>
                    </div>
                ))}
                {livros.filter(l => !selectedCollection.books.includes(l.id)).length === 0 && (
                  <p className="text-muted text-center">Todos os livros do catálogo já estão nesta coleção.</p>
                )}
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Modal Nova Coleção */}
      {showColModal && (
        <div className="modal-overlay fade-in" onClick={() => setShowColModal(false)}>
          <div className="modal-content col-modal animate-pop" onClick={e => e.stopPropagation()}>
            <div className="col-modal-header">
              <div className="col-modal-icon">{Icons.folder}</div>
              <h2>Criar Nova Coleção</h2>
              <p>Organize seus livros favoritos em coleções personalizadas</p>
              <button className="btn-close" onClick={() => setShowColModal(false)} aria-label="Fechar">{Icons.x}</button>
            </div>
            <form className="col-modal-form" onSubmit={handleCreateCollection}>
              <div className="input-group">
                <label>Nome da Coleção</label>
                <input type="text" placeholder="Ex: Clássicos da Ficção Científica" value={newCol.name} onChange={e => setNewCol({ ...newCol, name: e.target.value })} maxLength="255" required />
              </div>
              <div className="input-group">
                <label>Descrição <span className="optional-tag">(opcional)</span></label>
                <textarea rows="3" placeholder="Descreva sua coleção..." value={newCol.description} onChange={e => setNewCol({ ...newCol, description: e.target.value })} maxLength="500"></textarea>
              </div>
              <div className="toggle-group">
                <label className="toggle-switch">
                  <input type="checkbox" checked={newCol.is_public} onChange={e => setNewCol({ ...newCol, is_public: e.target.checked })} />
                  <span className="toggle-slider"></span>
                </label>
                <div className="toggle-label">
                  <strong>Coleção Pública</strong>
                  <small>Outros usuários poderão visualizar esta coleção</small>
                </div>
              </div>
              <div className="modal-actions">
                <button type="button" className="btn-cancel" onClick={() => setShowColModal(false)}>Cancelar</button>
                <button type="submit" className="btn-save">Criar Coleção</button>
              </div>
            </form>
          </div>
        </div>
      )}

      {/* Modal Selecionador de Coleção (Novo Componente) */}
      {bookToCollect && (
        <div className="modal-overlay fade-in" onClick={() => setBookToCollect(null)}>
          <div className="modal-content col-selector-modal animate-pop" onClick={e => e.stopPropagation()}>
            <div className="col-modal-header">
              <div className="col-modal-icon">{Icons.folder}</div>
              <h2>Adicionar à Coleção</h2>
              <p>Selecione a coleção para salvar este livro</p>
              <button className="btn-close" onClick={() => setBookToCollect(null)} aria-label="Fechar">{Icons.x}</button>
            </div>
            <div className="col-selector-body">
              <div className="search-pill" style={{ marginBottom: '1.5rem' }}>
                <div className="search-icon">{Icons.search}</div>
                <input 
                  type="text" 
                  placeholder="Buscar coleção..." 
                  value={colSearch} 
                  onChange={(e) => setColSearch(e.target.value)} 
                />
              </div>
              
              {myCollections.length === 0 ? (
                <div className="empty-state-mini">
                  <p>Você ainda não tem coleções.</p>
                  <button className="btn-action" style={{marginTop: '0.5rem'}} onClick={() => { setBookToCollect(null); setShowColModal(true); }}>
                    Criar Nova Coleção
                  </button>
                </div>
              ) : (
                <div className="collection-list-modern">
                  {myCollections
                    .filter(c => c.name.toLowerCase().includes(colSearch.toLowerCase()))
                    .map(c => {
                      const isAdded = c.books.includes(bookToCollect);
                      return (
                        <div 
                          key={c.id} 
                          className={`col-list-item ${isAdded ? 'added' : ''}`}
                          onClick={() => {
                            if (!isAdded) {
                              addBookToCollection(c.id, bookToCollect);
                            } else {
                              removeBookFromCollection(c.id, bookToCollect);
                            }
                          }}
                        >
                          <div className="col-item-left">
                            <div className={`col-checkbox ${isAdded ? 'checked' : ''}`}>
                              {isAdded && Icons.check}
                            </div>
                            <div className="col-item-info">
                              <strong>{c.name}</strong>
                              <span>{c.books.length} livros</span>
                            </div>
                          </div>
                        </div>
                      );
                  })}
                </div>
              )}
            </div>
          </div>
        </div>
      )}

    </div>
  )
}

export default App
