/* ===== Toast Component ===== */
function Toast({ message, type, onClose }) {
  useEffect(() => {
    const timer = setTimeout(onClose, 3500);
    return () => clearTimeout(timer);
  }, [onClose]);

  return (
    <div className={`toast ${type}`}>
      {type === 'success' ? Icons.check : Icons.alertCircle}
      <span>{message}</span>
    </div>
  );
}

/* ===== Main App ===== */
function App() {
  const [livros, setLivros] = useState([]);
  const [busca, setBusca] = useState('');
  const [loading, setLoading] = useState(false);
  const [isMenuOpen, setIsMenuOpen] = useState(false);
  const [isUserMenuOpen, setIsUserMenuOpen] = useState(false);
  const userMenuRef = useRef(null);
  const [view, setView] = useState(() => {
    if (typeof window !== 'undefined') {
      const hash = window.location.hash.replace('#/', '');
      return hash || sessionStorage.getItem('currentView') || 'landing';
    }
    return 'landing';
  });

  // Close user dropdown on outside click
  useEffect(() => {
    const handleClickOutside = (event) => {
      if (userMenuRef.current && !userMenuRef.current.contains(event.target)) {
        setIsUserMenuOpen(false);
      }
    };
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, []);

  // Watch for view changes and store in sessionStorage and Hash
  useEffect(() => {
    sessionStorage.setItem('currentView', view);
    if (window.location.hash.replace('#/', '') !== view) {
      window.location.hash = `/${view}`;
    }
  }, [view]);

  // Listen to external hash changes (Back/Forward buttons)
  useEffect(() => {
    const handleHashChange = () => {
      const hash = window.location.hash.replace('#/', '');
      if (hash && hash !== view) {
        setView(hash);
      }
    };
    window.addEventListener('hashchange', handleHashChange);
    return () => window.removeEventListener('hashchange', handleHashChange);
  }, [view]);
  const [selectedBook, setSelectedBook] = useState(null);
  
  // Advanced Filters (F-4)
  const [categoriaFilter, setCategoriaFilter] = useState('');
  const [tipoEdicaoFilter, setTipoEdicaoFilter] = useState('');
  const [anoFilter, setAnoFilter] = useState('');
  const [categoriasLista, setCategoriasLista] = useState([]);
  const [pagination, setPagination] = useState({ page: 1, pages: 1, total: 0 });

  // Notificacoes (F-2)
  const [notificacoes, setNotificacoes] = useState([]);
  const [unreadCount, setUnreadCount] = useState(0);

  // Multas (F-1)
  const [multas, setMultas] = useState([]);
  const [multasSummary, setMultasSummary] = useState(null);

  // Avaliacoes (F-3)
  const [avaliacoes, setAvaliacoes] = useState([]);
  const [minhaAvaliacao, setMinhaAvaliacao] = useState({ nota: 5, comentario: '' });
  const [hoverNota, setHoverNota] = useState(0);
  const [mediaLivro, setMediaLivro] = useState({ media: 0, total: 0 });
  const [topLivros, setTopLivros] = useState([]);
  const [sortAvaliacoes, setSortAvaliacoes] = useState('recentes');

  // Estatisticas (F-5)
  const [estatisticas, setEstatisticas] = useState(null);
  
  // Persist login state
  const [user, setUser] = useState(() => {
    if (typeof window === 'undefined') return null;
    const saved = sessionStorage.getItem('user');
    try {
      return saved && saved !== "undefined" ? JSON.parse(saved) : null;
    } catch (e) {
      sessionStorage.removeItem('user');
      return null;
    }
  });
  const isLoggedIn = !!user;
  const isAdmin = user && user.role === 'admin';
  const token = typeof window !== 'undefined' ? sessionStorage.getItem('token') : null;
  
  const [showAddModal, setShowAddModal] = useState(false);
  const [toast, setToast] = useState(null);

  const [loginUser, setLoginUser] = useState('');
  const [loginPass, setLoginPass] = useState('');
  
  // New States for Auth/Users
  const [regUser, setRegUser] = useState('');
  const [regEmail, setRegEmail] = useState('');
  const [regPass, setRegPass] = useState('');
  const [regConfirm, setRegConfirm] = useState('');
  const [usersList, setUsersList] = useState([]);
  
  // Collections & Favorites
  const [favorites, setFavorites] = useState([]);
  const [myCollections, setMyCollections] = useState([]);
  const [publicCollections, setPublicCollections] = useState([]);
  
  // Emprestimos
  const [borrowedBooks, setBorrowedBooks] = useState([]);
  const [myLoan, setMyLoan] = useState(null);
  const [allLoans, setAllLoans] = useState([]);
  const [adminTab, setAdminTab] = useState('users');
  const [adminNotif, setAdminNotif] = useState({ tipo_envio: 'broadcast', user_id: '', titulo: '', mensagem: '', tipo_msg: 'info' });
  const [showColModal, setShowColModal] = useState(false);
  const [newCol, setNewCol] = useState({ name: '', description: '', is_public: false });
  const [bookToCollect, setBookToCollect] = useState(null);
  const [collectionTab, setCollectionTab] = useState('mine');
  const [colSearch, setColSearch] = useState('');
  const [newBook, setNewBook] = useState({ titulo: '', autor: '', ano: '', categoria: '', sinopse: '', tipo_edicao: '', capa: null });
  const [authorSuggestions, setAuthorSuggestions] = useState([]);
  const [showAuthorSuggestions, setShowAuthorSuggestions] = useState(false);
  const [selectedCollection, setSelectedCollection] = useState(null);
  const [showAddBookToColModal, setShowAddBookToColModal] = useState(false);
  const [addBookColSearch, setAddBookColSearch] = useState('');

  const showToast = useCallback((message, type = 'success') => {
    setToast({ message, type });
  }, []);

  const fetchLivros = async (termo = '', page = 1) => {
    setLoading(true);
    try {
      let query = `?page=${page}&per_page=12`;
      if (termo) query += `&q=${encodeURIComponent(termo)}`;
      if (categoriaFilter) query += `&categoria=${categoriaFilter}`;
      if (anoFilter) query += `&ano_min=${anoFilter}`;
      
      const url = enabledFeatures.includes('busca-service')
        ? `http://localhost:8080/busca-service/busca${query}`
        : `http://localhost:8080/catalogo-service/livros${query}`;
        
      const response = await fetch(url);
      if (response.ok) {
        const data = await response.json();
        if (data.items) {
          setLivros(data.items);
          setPagination({ page: data.page, pages: data.pages, total: data.total });
        } else {
          setLivros(Array.isArray(data) ? data : []);
        }
      }
    } catch (error) {
      console.error("Erro ao buscar livros:", error);
    } finally {
      setLoading(false);
    }
  };

  const fetchCategoriasLista = async () => {
    try {
      const url = enabledFeatures.includes('busca-service')
        ? 'http://localhost:8080/busca-service/busca/categorias'
        : 'http://localhost:8080/catalogo-service/livros/categorias';
      const response = await fetch(url);
      if (response.ok) setCategoriasLista(await response.json());
    } catch (e) { console.error(e); }
  };

  // Notificacoes API
  const fetchNotificacoes = async () => {
    if (!isLoggedIn || !enabledFeatures.includes('notificacao-service')) return;
    try {
      const res = await fetch('http://localhost:8080/notificacao-service/notificacoes/me', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) setNotificacoes(await res.json());
      
      const resCount = await fetch('http://localhost:8080/notificacao-service/notificacoes/count', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (resCount.ok) {
        const data = await resCount.json();
        setUnreadCount(data.unread_count);
      }
    } catch (e) { console.error(e); }
  };

  const markNotifRead = async (id) => {
    if (!enabledFeatures.includes('notificacao-service')) return;
    try {
      await fetch(`http://localhost:8080/notificacao-service/notificacoes/${id}/ler`, {
        method: 'PUT', headers: { 'Authorization': `Bearer ${token}` }
      });
      fetchNotificacoes();
    } catch (e) { console.error(e); }
  };

  const markAllNotifRead = async () => {
    if (!enabledFeatures.includes('notificacao-service')) return;
    try {
      await fetch('http://localhost:8080/notificacao-service/notificacoes/ler-todas', {
        method: 'PUT', headers: { 'Authorization': `Bearer ${token}` }
      });
      fetchNotificacoes();
    } catch (e) { console.error(e); }
  };

  // Multas API
  const fetchMultas = async () => {
    if (!isLoggedIn || !enabledFeatures.includes('multa-service')) return;
    try {
      const res = await fetch('http://localhost:8080/multa-service/multas/me', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) setMultas(await res.json());
      
      if (isAdmin) {
        const resSum = await fetch('http://localhost:8080/multa-service/multas/resumo', {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if (resSum.ok) setMultasSummary(await resSum.json());
      }
    } catch (e) { console.error(e); }
  };

  const payMulta = async (id) => {
    if (!enabledFeatures.includes('multa-service')) return;
    try {
      const res = await fetch(`http://localhost:8080/multa-service/multas/${id}/pagar`, {
        method: 'PUT', headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        showToast('Multa paga com sucesso!');
        fetchMultas();
      }
    } catch (e) { console.error(e); }
  };

  // Avaliacoes API
  const fetchAvaliacoes = async (bookId) => {
    if (!enabledFeatures.includes('avaliacao-service')) return;
    try {
      const res = await fetch(`http://localhost:8080/avaliacao-service/avaliacoes/${bookId}`);
      if (res.ok) setAvaliacoes(await res.json());
      
      const resMedia = await fetch(`http://localhost:8080/avaliacao-service/avaliacoes/${bookId}/media`);
      if (resMedia.ok) setMediaLivro(await resMedia.json());
    } catch (e) { console.error(e); }
  };

  const submitAvaliacao = async (bookId) => {
    if (!enabledFeatures.includes('avaliacao-service')) return;
    if (!isLoggedIn) return showToast('Faça login para avaliar', 'error');
    try {
      const res = await fetch(`http://localhost:8080/avaliacao-service/avaliacoes/${bookId}`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
        body: JSON.stringify(minhaAvaliacao)
      });
      if (res.ok) {
        showToast('Avaliação salva!');
        setMinhaAvaliacao({ nota: 5, comentario: '' });
        setHoverNota(0);
        fetchAvaliacoes(bookId);
      }
    } catch (e) { console.error(e); }
  };

  const fetchTopLivros = async () => {
    if (!enabledFeatures.includes('avaliacao-service')) return;
    try {
      const res = await fetch('http://localhost:8080/avaliacao-service/avaliacoes/top');
      if (res.ok) setTopLivros(await res.json());
    } catch (e) { console.error(e); }
  };

  // Estatisticas API
  const fetchEstatisticas = async () => {
    if (!enabledFeatures.includes('busca-service')) return;
    try {
      const res = await fetch('http://localhost:8080/busca-service/busca/estatisticas');
      if (res.ok) setEstatisticas(await res.json());
    } catch (e) { console.error(e); }
  };

  const openBookDetails = (livro) => {
    setSelectedBook(livro);
    setView('book-details');
    fetchAvaliacoes(livro.id);
  };

  useEffect(() => {
    fetchLivros(busca, pagination.page);
    fetchCategoriasLista();
    fetchTopLivros();
    if (enabledFeatures.includes('emprestimo-service')) {
      fetchBorrowedBooks();
    }
    if (enabledFeatures.includes('busca-service')) {
      fetchEstatisticas();
    }
  }, [categoriaFilter, anoFilter, pagination.page]);

  useEffect(() => {
    if (isLoggedIn) {
      fetchNotificacoes();
      fetchMultas();
    }
  }, [isLoggedIn, view]);

  useEffect(() => {
    const delayDebounceFn = setTimeout(() => {
      if (view === 'landing') fetchLivros(busca);
    }, 500);
    return () => clearTimeout(delayDebounceFn);
  }, [busca]);

  const handleLogin = async (e) => {
    e.preventDefault();
    try {
      const formData = new URLSearchParams();
      formData.append('username', loginUser);
      formData.append('password', loginPass);

      const response = await fetch('http://localhost:8080/auth-service/auth/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: formData.toString()
      });

      if (response.ok) {
        const data = await response.json();
        sessionStorage.setItem('token', data.access_token);
        sessionStorage.setItem('user', JSON.stringify(data.user));
        setUser(data.user);
        setView('landing');
        setLoginUser('');
        setLoginPass('');
        showToast('Autenticado com sucesso!');
      } else {
        // Fallback for when auth-service is not selected/available
        if (loginUser.trim() === 'admin' && loginPass.trim() === 'admin') {
          const adminUser = { username: 'admin', role: 'admin' };
          sessionStorage.setItem('user', JSON.stringify(adminUser));
          sessionStorage.setItem('token', 'fallback-admin-token');
          setUser(adminUser);
          setView('landing');
          setLoginUser('');
          setLoginPass('');
          showToast('Autenticado com sucesso (fallback admin)!');
        } else {
          showToast('Credenciais inválidas. Tente novamente.', 'error');
        }
      }
    } catch (err) {
      // Fallback
      if (loginUser.trim() === 'admin' && loginPass.trim() === 'admin') {
        const adminUser = { username: 'admin', role: 'admin' };
        sessionStorage.setItem('user', JSON.stringify(adminUser));
        sessionStorage.setItem('token', 'fallback-admin-token');
        setUser(adminUser);
        setView('landing');
        setLoginUser('');
        setLoginPass('');
        showToast('Autenticado com sucesso (fallback admin)!');
      } else {
        showToast('Erro de conexão ou credenciais inválidas.', 'error');
      }
    }
  };

  const handleLogout = () => {
    sessionStorage.removeItem('user');
    sessionStorage.removeItem('token');
    setUser(null);
    setIsMenuOpen(false);
    setFavorites([]);
    setMyCollections([]);
    setView('landing');
    showToast('Sessão encerrada.');
  };

  const handleRegister = async (e) => {
    e.preventDefault();
    if (!enabledFeatures.includes('auth-service')) return;
    if (regPass !== regConfirm) {
      showToast('As senhas não coincidem.', 'error');
      return;
    }
    try {
      const response = await fetch('http://localhost:8080/auth-service/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username: regUser, email: regEmail, password: regPass })
      });
      if (response.ok) {
        showToast('Conta criada com sucesso! Faça login.');
        setView('login');
        setRegUser(''); setRegEmail(''); setRegPass(''); setRegConfirm('');
      } else {
        const err = await response.json();
        showToast(err.detail || 'Erro ao registrar.', 'error');
      }
    } catch (err) {
      showToast('Erro de conexão.', 'error');
    }
  };

  const fetchFavorites = async () => {
    try {
      const res = await fetch('http://localhost:8080/auth-service/favorites', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        const data = await res.json();
        setFavorites(data);
      }
    } catch (e) { console.error(e); }
  };

  const toggleFavorite = async (bookId) => {
    if (!isLoggedIn) return showToast('Faça login para favoritar.', 'error');
    try {
      const res = await fetch(`http://localhost:8080/auth-service/favorites/${bookId}`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        const data = await res.json();
        if (data.action === 'added') setFavorites([...favorites, bookId]);
        else setFavorites(favorites.filter(id => id !== bookId));
      }
    } catch (e) { console.error(e); }
  };
  
  useEffect(() => {
    if (isLoggedIn && token) {
      if (enabledFeatures.includes('auth-service')) fetchFavorites();
      if (enabledFeatures.includes('emprestimo-service')) fetchMyLoan();
    }
  }, [isLoggedIn, token]);

  useEffect(() => {
    if (view === 'collections' && isLoggedIn && token && enabledFeatures.includes('auth-service')) {
      fetchMyCollections();
      fetchPublicCollections();
    }
  }, [view]);

  useEffect(() => {
    if (view === 'admin-panel' && isAdmin && token) {
      if (adminTab === 'users' && enabledFeatures.includes('auth-service')) fetchUsers();
      if (adminTab === 'loans' && enabledFeatures.includes('emprestimo-service')) fetchAllLoans();
    }
  }, [view, adminTab]);

  const sendAdminNotif = async (e) => {
    e.preventDefault();
    if (!enabledFeatures.includes('notificacao-service')) return;
    try {
      let finalUserId = adminNotif.user_id;
      if (adminNotif.tipo_envio === 'direto') {
        const targetUser = usersList.find(u => u.username.toLowerCase() === finalUserId.toLowerCase() || u.id.toString() === finalUserId);
        if (targetUser) {
          finalUserId = targetUser.id;
        } else {
          return showToast('Usuário não encontrado.', 'error');
        }
      }
      const endpoint = adminNotif.tipo_envio === 'broadcast' 
        ? 'http://localhost:8080/notificacao-service/notificacoes/broadcast'
        : 'http://localhost:8080/notificacao-service/notificacoes';
      
      const payload = adminNotif.tipo_envio === 'broadcast' 
        ? { titulo: adminNotif.titulo, mensagem: adminNotif.mensagem, tipo: adminNotif.tipo_msg }
        : { user_id: parseInt(finalUserId), titulo: adminNotif.titulo, mensagem: adminNotif.mensagem, tipo: adminNotif.tipo_msg };

      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify(payload)
      });

      if (res.ok) {
        showToast('Notificação enviada com sucesso!', 'success');
        setAdminNotif({...adminNotif, titulo: '', mensagem: ''});
      } else {
        showToast('Erro ao enviar notificação.', 'error');
      }
    } catch (e) { console.error(e); }
  };

  const fetchMyCollections = async () => {
    if (!enabledFeatures.includes('auth-service')) return;
    try {
      const res = await fetch('http://localhost:8080/auth-service/collections/me', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        const data = await res.json();
        setMyCollections(data);
      }
    } catch (e) { console.error(e); }
  };

  const fetchPublicCollections = async () => {
    if (!enabledFeatures.includes('auth-service')) return;
    try {
      const res = await fetch('http://localhost:8080/auth-service/collections', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        const data = await res.json();
        setPublicCollections(data);
      }
    } catch (e) { console.error(e); }
  };

  const fetchUsers = async () => {
    if (!enabledFeatures.includes('auth-service')) return;
    try {
      const res = await fetch('http://localhost:8080/auth-service/users', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        const data = await res.json();
        setUsersList(data);
      }
    } catch (e) { console.error(e); }
  };

  const fetchBorrowedBooks = async () => {
    if (!enabledFeatures.includes('emprestimo-service')) return;
    try {
      const res = await fetch('http://localhost:8080/emprestimo-service/status');
      if (res.ok) setBorrowedBooks(await res.json());
    } catch (e) { console.error(e); }
  };

  const fetchMyLoan = async () => {
    if (!enabledFeatures.includes('emprestimo-service')) return;
    try {
      const res = await fetch('http://localhost:8080/emprestimo-service/me', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) setMyLoan(await res.json());
      else setMyLoan(null);
    } catch (e) { console.error(e); }
  };

  const fetchAllLoans = async () => {
    if (!enabledFeatures.includes('emprestimo-service')) return;
    try {
      const res = await fetch('http://localhost:8080/emprestimo-service/all', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) setAllLoans(await res.json());
    } catch (e) { console.error(e); }
  };

  const handleBorrow = async (bookId) => {
    if (!enabledFeatures.includes('emprestimo-service')) return;
    if (!isLoggedIn) return showToast('Faça login para emprestar.', 'error');
    try {
      const res = await fetch(`http://localhost:8080/emprestimo-service/${bookId}`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        showToast(
          <div style={{ display: 'flex', flexDirection: 'column', gap: '0.25rem' }}>
            <span>Empréstimo realizado com sucesso!</span>
            <small style={{ opacity: 0.8 }}>Você pode desfazer a qualquer momento na opção Devolver.</small>
          </div>
        );
        fetchBorrowedBooks();
        fetchMyLoan();
      } else {
        const err = await res.json();
        showToast(err.detail || 'Erro ao realizar empréstimo.', 'error');
      }
    } catch (e) { showToast('Erro de conexão.', 'error'); }
  };

  const handleReturn = async (bookId) => {
    if (!enabledFeatures.includes('emprestimo-service')) return;
    if (!isLoggedIn) return;
    try {
      const res = await fetch(`http://localhost:8080/emprestimo-service/${bookId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        showToast('Livro devolvido com sucesso!');
        fetchBorrowedBooks();
        fetchMyLoan();
        if (isAdmin) fetchAllLoans();
      } else {
        const err = await res.json();
        showToast(err.detail || 'Erro ao devolver livro.', 'error');
      }
    } catch (e) { showToast('Erro de conexão.', 'error'); }
  };

  const handleCreateCollection = async (e) => {
    e.preventDefault();
    try {
      const res = await fetch('http://localhost:8080/auth-service/collections', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify(newCol)
      });
      if (res.ok) {
        showToast('Coleção criada com sucesso!');
        setShowColModal(false);
        setNewCol({ name: '', description: '', is_public: false });
        fetchMyCollections();
      }
    } catch (e) { showToast('Erro ao criar coleção', 'error'); }
  };

  const removeBookFromCollection = async (collectionId, bookId) => {
    try {
      const res = await fetch(`http://localhost:8080/auth-service/collections/${collectionId}/books/${bookId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        showToast('Livro removido da coleção!');
        fetchMyCollections();
        fetchPublicCollections();
        if (selectedCollection && selectedCollection.id === collectionId) {
          setSelectedCollection({
            ...selectedCollection,
            books: selectedCollection.books.filter(id => id !== bookId)
          });
        }
      } else {
        showToast('Erro ao remover livro', 'error');
      }
    } catch (e) { console.error(e); }
  };

  const addBookToCollection = async (collectionId, bookId) => {
    try {
      const res = await fetch(`http://localhost:8080/auth-service/collections/${collectionId}/books/${bookId}`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        showToast('Livro adicionado à coleção!');
        fetchMyCollections();
        setBookToCollect(null);
        if (selectedCollection && selectedCollection.id === collectionId) {
          setSelectedCollection({
            ...selectedCollection,
            books: [...selectedCollection.books, bookId]
          });
          setShowAddBookToColModal(false);
          setAddBookColSearch('');
        }
      } else {
        showToast('Erro ou livro já na coleção', 'error');
      }
    } catch (e) { console.error(e); }
  };

  const changeUserRole = async (userId, newRole) => {
    try {
      const res = await fetch(`http://localhost:8080/auth-service/users/${userId}/role?role=${newRole}`, {
        method: 'PUT',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        showToast('Permissão atualizada!');
        fetchUsers();
      }
    } catch (e) { console.error(e); }
  };

  const fetchAuthorSuggestions = async (query) => {
    if (query.length < 3) {
      setAuthorSuggestions([]);
      setShowAuthorSuggestions(false);
      return;
    }
    try {
      const response = await fetch(`http://localhost:8080/catalogo-service/autores?q=${encodeURIComponent(query)}`);
      if (response.ok) {
        const data = await response.json();
        setAuthorSuggestions(data);
        setShowAuthorSuggestions(data.length > 0);
      }
    } catch (err) {
      console.error("Erro ao buscar autores", err);
    }
  };

  const handleAuthorChange = (e) => {
    const val = e.target.value;
    setNewBook({ ...newBook, autor: val });
    fetchAuthorSuggestions(val);
  };

  const selectAuthor = (autor) => {
    setNewBook({ ...newBook, autor });
    setShowAuthorSuggestions(false);
  };

  const handleAddBook = async (e) => {
    e.preventDefault();
    try {
      const formData = new FormData();
      formData.append('titulo', newBook.titulo);
      formData.append('autor', newBook.autor);
      if (newBook.ano) formData.append('ano', newBook.ano);
      if (newBook.categoria) formData.append('categoria', newBook.categoria);
      if (newBook.sinopse) formData.append('sinopse', newBook.sinopse);
      if (newBook.tipo_edicao) formData.append('tipo_edicao', newBook.tipo_edicao);
      if (newBook.capa) formData.append('capa', newBook.capa);

      const response = await fetch('http://localhost:8080/catalogo-service/livros', {
        method: 'POST',
        body: formData
      });
      if (response.ok) {
        setShowAddModal(false);
        setNewBook({ titulo: '', autor: '', ano: '', categoria: '', sinopse: '', tipo_edicao: '', capa: null });
        fetchLivros();
        showToast('Livro adicionado com sucesso!');
      } else {
        showToast('Erro ao salvar livro. Verifique os dados.', 'error');
      }
    } catch (err) {
      showToast('Erro ao adicionar livro. Tente novamente.', 'error');
    }
  };

  const getCoverGradient = (title) => {
    if (!title) return 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
    const gradients = [
      'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
      'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)',
      'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
      'linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)',
      'linear-gradient(135deg, #fa709a 0%, #fee140 100%)',
      'linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%)',
      'linear-gradient(135deg, #fccb90 0%, #d57eeb 100%)',
      'linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%)',
      'linear-gradient(135deg, #f5576c 0%, #ff6a88 50%, #fccb90 100%)',
      'linear-gradient(135deg, #667eea 0%, #00d2ff 100%)',
    ];
    let hash = 0;
    for (let i = 0; i < title.length; i++) {
      hash = title.charCodeAt(i) + ((hash << 5) - hash);
    }
    return gradients[Math.abs(hash) % gradients.length];
  };

  return (
    <div className="app-container">
      {/* Toast */}
      {toast && (
        <Toast
          message={toast.message}
          type={toast.type}
          onClose={() => setToast(null)}
        />
      )}

      {/* Navbar */}
      <nav className="navbar">
        <div className="nav-content">
          <div className="nav-brand" onClick={() => setView('landing')}>
            <span className="logo-icon">
              <svg viewBox="0 0 24 24" fill="white" width="20" height="20">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" stroke="white" fill="none" strokeWidth="2" strokeLinecap="round"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" stroke="white" fill="none" strokeWidth="2" strokeLinecap="round"/>
              </svg>
            </span>
            <span>LibLPS</span>
          </div>

          <div
            className={`nav-toggle ${isMenuOpen ? 'open' : ''}`}
            onClick={() => setIsMenuOpen(!isMenuOpen)}
          >
            <span></span>
            <span></span>
            <span></span>
          </div>

          <ul className={`nav-links ${isMenuOpen ? 'active' : ''}`}>
            <button
              className={`nav-pill-btn ${view === 'landing' ? 'active' : ''}`}
              onClick={() => { setView('landing'); setIsMenuOpen(false); }}
            >
              {Icons.search} <span>Explorar</span>
            </button>
            {enabledFeatures.includes('busca-service') && (
              <button
                className={`nav-pill-btn ${view === 'estatisticas' ? 'active' : ''}`}
                onClick={() => { setView('estatisticas'); setIsMenuOpen(false); }}
              >
                {Icons.chart} <span>Estatísticas</span>
              </button>
            )}
            {!isLoggedIn ? (
              <>
                <button
                  className={`nav-pill-btn ${view === 'login' ? 'active' : ''}`}
                  onClick={() => { setView('login'); setIsMenuOpen(false); }}
                >
                  {Icons.user} <span>Entrar</span>
                </button>
                {enabledFeatures.includes('auth-service') && (
                  <button
                    className={`nav-pill-btn ${view === 'register' ? 'active' : ''}`}
                    onClick={() => { setView('register'); setIsMenuOpen(false); }}
                  >
                    {Icons.plus} <span>Cadastrar</span>
                  </button>
                )}
              </>
            ) : (
              <div className="nav-user-menu">
                {enabledFeatures.includes('auth-service') && (
                  <>
                    <button className={`nav-pill-btn ${view === 'favorites' ? 'active' : ''}`} onClick={() => { setView('favorites'); setIsMenuOpen(false); }}>
                      {Icons.heart} <span>Favoritos</span>
                    </button>
                    <button className={`nav-pill-btn ${view === 'collections' ? 'active' : ''}`} onClick={() => { setView('collections'); setIsMenuOpen(false); }}>
                      {Icons.folder} <span>Coleções</span>
                    </button>
                  </>
                )}
                {enabledFeatures.includes('emprestimo-service') && (
                  <button className={`nav-pill-btn ${view === 'my-loan' ? 'active' : ''}`} onClick={() => { setView('my-loan'); setIsMenuOpen(false); }}>
                    {Icons.book} <span>Empréstimos</span>
                  </button>
                )}
                {enabledFeatures.includes('multa-service') && (
                  <button className={`nav-pill-btn ${view === 'multas' ? 'active' : ''}`} onClick={() => { setView('multas'); setIsMenuOpen(false); }}>
                    {Icons.dollar} <span>Multas</span>
                  </button>
                )}
                
                <div className="nav-divider"></div>

                {enabledFeatures.includes('notificacao-service') && (
                  <button className={`nav-bell-btn ${view === 'notificacoes' ? 'active' : ''}`} onClick={() => { setView('notificacoes'); setIsMenuOpen(false); }} title="Notificações">
                    {Icons.bell}
                    {unreadCount > 0 && <span className="bell-dot"></span>}
                  </button>
                )}
                
                {/* Perfil Dropdown / Actions */}
                <div className="nav-profile-group">
                  {isAdmin && enabledFeatures.includes('auth-service') && (
                    <button className={`nav-pill-btn ${view === 'admin-panel' ? 'active' : ''}`} onClick={() => { setView('admin-panel'); setIsMenuOpen(false); }}>
                      {Icons.lock} <span>Admin</span>
                    </button>
                  )}
                  <div className="user-dropdown-container" ref={userMenuRef}>
                    <button
                      className="user-pill-modern user-pill-clickable"
                      onClick={() => setIsUserMenuOpen(!isUserMenuOpen)}
                      aria-expanded={isUserMenuOpen}
                      aria-haspopup="true"
                    >
                      <div className="user-avatar">{user.username.charAt(0).toUpperCase()}</div>
                      <span>{user.username}</span>
                      <svg className={`user-pill-chevron ${isUserMenuOpen ? 'open' : ''}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" width="14" height="14">
                        <polyline points="6 9 12 15 18 9"/>
                      </svg>
                    </button>
                    {isUserMenuOpen && (
                      <div className="user-dropdown-menu">
                        <button className="user-dropdown-item" onClick={() => { setView('profile'); setIsUserMenuOpen(false); setIsMenuOpen(false); }}>
                          {Icons.user} <span>Meu Perfil</span>
                        </button>
                        <div className="user-dropdown-divider"></div>
                        <button className="user-dropdown-item user-dropdown-danger" onClick={() => { handleLogout(); setIsUserMenuOpen(false); }}>
                          {Icons.logOut} <span>Sair</span>
                        </button>
                      </div>
                    )}
                  </div>
