                </div>
              </div>
            </article>

            {enabledFeatures.includes('avaliacao-service') && (
              <section className="avaliacoes-section mt-4" style={{ marginTop: '3rem', borderTop: '1px solid #e2e8f0', paddingTop: '2rem' }}>
                <div style={{display: 'flex', alignItems: 'center', gap: '1rem', marginBottom: '1.5rem'}}>
                  <h3 style={{margin: 0}}>Avaliações</h3>
                  <div className="badge-review">
                    <span style={{color: '#fbbf24'}}>{Icons.starFilled}</span>
                    <strong>{mediaLivro.media ? mediaLivro.media.toFixed(1) : '0.0'}</strong>
                    <span style={{color: '#64748b', fontSize: '0.9rem'}}>({mediaLivro.total || 0} avaliações)</span>
