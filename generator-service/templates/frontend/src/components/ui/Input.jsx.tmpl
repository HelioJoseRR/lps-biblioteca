import React from 'react';

export default function Input({ label, type = 'text', ...props }) {
  return (
    <div className="input-group">
      {label && <label>{label}</label>}
      {type === 'textarea' ? (
        <textarea {...props} />
      ) : (
        <input type={type} {...props} />
      )}
    </div>
  );
}
