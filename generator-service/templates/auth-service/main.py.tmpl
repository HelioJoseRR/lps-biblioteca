@app.post("/collections", tags=["Coleções"])
async def create_collection(collection: CollectionCreate, current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    with conn.cursor(cursor_factory=RealDictCursor) as cur:
        cur.execute("INSERT INTO collections (user_id, name, description, is_public) VALUES (%s, %s, %s, %s) RETURNING *",
                    (current_user['id'], collection.name, collection.description, collection.is_public))
        new_col = cur.fetchone()
        new_col['books'] = []
        conn.commit()
        return new_col

@app.get("/collections/me", tags=["Coleções"])
async def my_collections(current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    with conn.cursor(cursor_factory=RealDictCursor) as cur:
        cur.execute("SELECT * FROM collections WHERE user_id = %s", (current_user['id'],))
        cols = cur.fetchall()
        for col in cols:
            cur.execute("SELECT book_id FROM collection_books WHERE collection_id = %s", (col['id'],))
            col['books'] = [r['book_id'] for r in cur.fetchall()]
        return cols

@app.get("/collections", tags=["Coleções"])
async def public_collections(current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    with conn.cursor(cursor_factory=RealDictCursor) as cur:
        cur.execute("SELECT c.*, u.username as owner_name FROM collections c JOIN users u ON c.user_id = u.id WHERE c.is_public = true")
        cols = cur.fetchall()
        for col in cols:
            cur.execute("SELECT book_id FROM collection_books WHERE collection_id = %s", (col['id'],))
            col['books'] = [r['book_id'] for r in cur.fetchall()]
        return cols

@app.delete("/collections/{collection_id}", tags=["Coleções"])
async def delete_collection(collection_id: int, current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    with conn.cursor() as cur:
        cur.execute("SELECT id FROM collections WHERE id = %s AND user_id = %s", (collection_id, current_user['id']))
        if not cur.fetchone():
            raise HTTPException(status_code=403, detail="Coleção não encontrada ou acesso negado")
            
        cur.execute("DELETE FROM collections WHERE id = %s", (collection_id,))
        conn.commit()
        return {"message": "Coleção excluída com sucesso"}

@app.put("/collections/{collection_id}", tags=["Coleções"])
async def update_collection(collection_id: int, update: CollectionUpdate, current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    with conn.cursor(cursor_factory=RealDictCursor) as cur:
        cur.execute("SELECT id FROM collections WHERE id = %s AND user_id = %s", (collection_id, current_user['id']))
        if not cur.fetchone():
            raise HTTPException(status_code=403, detail="Coleção não encontrada ou acesso negado")
            
        campos = {}
        if update.name is not None: campos["name"] = update.name
        if update.description is not None: campos["description"] = update.description
        if update.is_public is not None: campos["is_public"] = update.is_public
        
        if not campos:
            raise HTTPException(status_code=400, detail="Nenhum campo para atualizar")
            
        set_clause = ", ".join([f"{k} = %s" for k in campos.keys()])
        values = list(campos.values()) + [collection_id]
        query = f"UPDATE collections SET {set_clause} WHERE id = %s RETURNING *"
        cur.execute(query, values)
        updated_col = cur.fetchone()
        conn.commit()
        return updated_col

@app.post("/collections/{collection_id}/books/{book_id}", tags=["Coleções"])
async def add_book_to_collection(collection_id: int, book_id: int, current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    with conn.cursor() as cur:
        cur.execute("SELECT id FROM collections WHERE id = %s AND user_id = %s", (collection_id, current_user['id']))
        if not cur.fetchone():
            raise HTTPException(status_code=403, detail="Coleção não encontrada ou acesso negado")
            
        try:
            cur.execute("INSERT INTO collection_books (collection_id, book_id) VALUES (%s, %s)", (collection_id, book_id))
            conn.commit()
            return {"message": "Livro adicionado à coleção"}
        except psycopg2.IntegrityError:
            conn.rollback()
            raise HTTPException(status_code=400, detail="Livro já está na coleção")

@app.delete("/collections/{collection_id}/books/{book_id}", tags=["Coleções"])
async def remove_book_from_collection(collection_id: int, book_id: int, current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    with conn.cursor() as cur:
        cur.execute("SELECT id FROM collections WHERE id = %s AND user_id = %s", (collection_id, current_user['id']))
        if not cur.fetchone():
            raise HTTPException(status_code=403, detail="Coleção não encontrada ou acesso negado")
            
        cur.execute("DELETE FROM collection_books WHERE collection_id = %s AND book_id = %s", (collection_id, book_id))
        conn.commit()
        return {"message": "Livro removido da coleção"}

