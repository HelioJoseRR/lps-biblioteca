@app.post("/favorites/{book_id}", tags=["Favoritos"])
async def toggle_favorite(book_id: int, current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    with conn.cursor() as cur:
        cur.execute("SELECT book_id FROM favorites WHERE user_id = %s AND book_id = %s", (current_user['id'], book_id))
        existing = cur.fetchone()
        
        if existing:
            cur.execute("DELETE FROM favorites WHERE user_id = %s AND book_id = %s", (current_user['id'], book_id))
            action = "removed"
        else:
            cur.execute("INSERT INTO favorites (user_id, book_id) VALUES (%s, %s)", (current_user['id'], book_id))
            action = "added"
        conn.commit()
        return {"action": action, "book_id": book_id}

@app.get("/favorites", tags=["Favoritos"])
async def get_favorites(current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    with conn.cursor(cursor_factory=RealDictCursor) as cur:
        cur.execute("SELECT book_id FROM favorites WHERE user_id = %s", (current_user['id'],))
        return [row['book_id'] for row in cur.fetchall()]
