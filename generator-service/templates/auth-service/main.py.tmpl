# AUTENTICAÇÃO E USUÁRIOS
# ============================
@app.post("/auth/register", tags=["Autenticação"])
async def register(user: UserRegister):
    conn = get_db_connection()
    if not conn:
        raise HTTPException(status_code=500, detail="Database connection failed")
        
    hashed_password = pwd_context.hash(user.password)
    try:
        with conn.cursor() as cur:
            cur.execute("INSERT INTO users (username, email, password_hash) VALUES (%s, %s, %s) RETURNING id, username, email, role", 
                        (user.username, user.email, hashed_password))
            new_user = cur.fetchone()
            conn.commit()
            return {"message": "Usuário registrado com sucesso", "user": {"id": new_user[0], "username": new_user[1], "email": new_user[2], "role": new_user[3]}}
    except psycopg2.IntegrityError:
        conn.rollback()
        raise HTTPException(status_code=400, detail="E-mail ou nome de usuário já existe")

@app.post("/auth/login", tags=["Autenticação"])
async def login(form_data: OAuth2PasswordRequestForm = Depends()):
    conn = get_db_connection()
    if not conn:
        raise HTTPException(status_code=500, detail="Database connection failed")
        
    with conn.cursor(cursor_factory=RealDictCursor) as cur:
        cur.execute("SELECT id, username, email, password_hash, role FROM users WHERE LOWER(email) = LOWER(%s) OR LOWER(username) = LOWER(%s)", 
                    (form_data.username, form_data.username))
        user = cur.fetchone()
        
    if not user:
        raise HTTPException(status_code=400, detail="Usuário ou senha incorretos")
        
    db_hash = user['password_hash']
    valid_password = False
    
    if not db_hash.startswith("$2"):
        if db_hash == form_data.password:
            valid_password = True
            new_hash = pwd_context.hash(form_data.password)
            with conn.cursor() as cur:
                cur.execute("UPDATE users SET password_hash = %s WHERE id = %s", (new_hash, user['id']))
                conn.commit()
    else:
        valid_password = pwd_context.verify(form_data.password, db_hash)
        
    if not valid_password:
        raise HTTPException(status_code=400, detail="Usuário ou senha incorretos")
        
    access_token_expires = timedelta(minutes=ACCESS_TOKEN_EXPIRE_MINUTES)
    expire = datetime.utcnow() + access_token_expires
    to_encode = {"sub": str(user['id']), "username": user['username'], "role": user['role'], "exp": expire}
    access_token = jwt.encode(to_encode, SECRET_KEY, algorithm=ALGORITHM)
    
    return {"access_token": access_token, "token_type": "bearer", "user": {"id": user['id'], "username": user['username'], "role": user['role']}}

@app.get("/users/me", tags=["Usuários"])
async def get_me(current_user: dict = Depends(get_current_user)):
    return current_user

class UserUpdate(BaseModel):
    username: Optional[str] = None
    email: Optional[str] = None

@app.put("/users/me", tags=["Usuários"])
async def update_me(update: UserUpdate, current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    if not conn:
        raise HTTPException(status_code=500, detail="Database connection failed")

    campos = {}
    if update.username is not None:
        campos["username"] = update.username
    if update.email is not None:
        campos["email"] = update.email

    if not campos:
        raise HTTPException(status_code=400, detail="Nenhum campo para atualizar")

    try:
        with conn.cursor(cursor_factory=RealDictCursor) as cur:
            set_clause = ", ".join([f"{k} = %s" for k in campos.keys()])
            values = list(campos.values()) + [current_user['id']]
            query = f"UPDATE users SET {set_clause} WHERE id = %s RETURNING id, username, email, role"
            cur.execute(query, values)
            updated_user = cur.fetchone()
            conn.commit()
            return updated_user
    except psycopg2.IntegrityError:
        conn.rollback()
        raise HTTPException(status_code=400, detail="E-mail ou nome de usuário já está em uso")

class PasswordChange(BaseModel):
    current_password: str
    new_password: str

@app.put("/users/me/password", tags=["Usuários"])
async def change_password(passwords: PasswordChange, current_user: dict = Depends(get_current_user)):
    conn = get_db_connection()
    if not conn:
        raise HTTPException(status_code=500, detail="Database connection failed")

    with conn.cursor(cursor_factory=RealDictCursor) as cur:
        cur.execute("SELECT password_hash FROM users WHERE id = %s", (current_user['id'],))
        user = cur.fetchone()

    if not user:
        raise HTTPException(status_code=404, detail="Usuário não encontrado")

    db_hash = user['password_hash']

    # Verifica a senha atual (suporta hash bcrypt e texto puro legado)
    if db_hash.startswith("$2"):
        if not pwd_context.verify(passwords.current_password, db_hash):
            raise HTTPException(status_code=400, detail="Senha atual incorreta")
    else:
        if db_hash != passwords.current_password:
            raise HTTPException(status_code=400, detail="Senha atual incorreta")

    # Valida a nova senha
    if len(passwords.new_password) < 4:
        raise HTTPException(status_code=400, detail="A nova senha deve ter no mínimo 4 caracteres")

    new_hash = pwd_context.hash(passwords.new_password)
    with conn.cursor() as cur:
        cur.execute("UPDATE users SET password_hash = %s WHERE id = %s", (new_hash, current_user['id']))
        conn.commit()

    return {"message": "Senha alterada com sucesso"}

