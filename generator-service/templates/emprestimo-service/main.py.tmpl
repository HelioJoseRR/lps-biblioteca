@app.get("/all", tags=["Admin"])
async def all_loans(current_user: dict = Depends(require_admin)):
    """Retorna todos os empréstimos ativos detalhados para o Painel Admin."""
    conn = get_db_connection()
    if not conn:
        raise HTTPException(status_code=500, detail="Database error")
        
    query = """
    SELECT e.id, e.user_id, e.book_id, e.data_emprestimo, e.prazo_devolucao, e.data_devolucao,
           u.username, u.email, 
           l.titulo,
           CASE 
               WHEN e.data_devolucao IS NULL AND e.prazo_devolucao < NOW() THEN true 
               ELSE false 
           END AS atrasado
    FROM emprestimos e
    JOIN users u ON e.user_id = u.id
    JOIN livros l ON e.book_id = l.id
    WHERE e.data_devolucao IS NULL
    ORDER BY e.data_emprestimo DESC
    """
    with conn.cursor(cursor_factory=RealDictCursor) as cur:
        cur.execute(query)
        return cur.fetchall()

@app.get("/atrasados", tags=["Admin"])
async def overdue_loans(current_user: dict = Depends(require_admin)):
    """Retorna todos os empréstimos ativos cujo prazo de devolução já expirou."""
    conn = get_db_connection()
    if not conn:
        raise HTTPException(status_code=500, detail="Database error")

    query = """
    SELECT e.id, e.user_id, e.book_id, e.data_emprestimo, e.prazo_devolucao,
           u.username, u.email,
           l.titulo,
           EXTRACT(DAY FROM NOW() - e.prazo_devolucao)::int AS dias_atraso
    FROM emprestimos e
    JOIN users u ON e.user_id = u.id
    JOIN livros l ON e.book_id = l.id
    WHERE e.data_devolucao IS NULL AND e.prazo_devolucao < NOW()
    ORDER BY e.prazo_devolucao ASC
    """
    with conn.cursor(cursor_factory=RealDictCursor) as cur:
        cur.execute(query)
        return cur.fetchall()
